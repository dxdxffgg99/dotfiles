{
	"custom/nowplaying": {
		"exec": "playerctl metadata --format '{{title}}' 2>/dev/null | sed -e 's/&/&amp;/g' -e 's/</&lt;/g' -e 's/>/&gt;/g' | awk '{t=$0; if(length(t)>20) t=substr(t,1,20)\"…\"; print \"<span rise=\\\"-1500\\\" size=\\\"14000\\\">󰝚</span> \" t}'",
		"interval": 2,
		"tooltip": false
	}
}
